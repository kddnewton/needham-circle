#!/usr/bin/env ruby

$:.unshift File.expand_path(File.join("..", "lib"), __dir__)
require "needham_circle"
require "irb"

module NeedhamCircle
  module IRBHelpers
    def secrets
      Env.secrets
    end

    def calendar
      GoogleCalendar.new(secrets.fetch("SERVICE_ACCOUNT_KEY"))
    end

    def lets_bike
      Sync::LetsBike.new(**sync_kwargs)
    end

    def lwv
      Sync::Lwv.new(**sync_kwargs)
    end

    def needham_gov
      Sync::NeedhamGov.new(**sync_kwargs)
    end

    def needham_rotary
      Sync::NeedhamRotary.new(**sync_kwargs)
    end

    private

    def sync_kwargs
      {
        calendar: calendar,
        calendar_id: secrets.fetch("EVENTS_CALENDAR_ID"),
        logger: Logger.new($stdout)
      }
    end
  end
end

extend NeedhamCircle::IRBHelpers
IRB.start

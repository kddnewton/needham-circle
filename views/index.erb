<h2 class="visually-hidden">Upcoming Events</h2>

<div class="event-filters" data-filters>
  <div class="filter-bar">
    <form class="filter-search-form" method="get" action="/">
      <% unless @filter.selected_sources.empty? %>
        <input type="hidden" name="source" value="<%= @filter.selected_sources.join(",") %>">
      <% end %>
      <input
        class="filter-search"
        type="search"
        name="q"
        placeholder="Search events"
        aria-label="Search events"
        value="<%= @filter.query %>"
        data-search
      >
    </form>
  </div>

  <div class="filter-sources">
    <% @filter.sources.each do |source| %>
      <% active = @filter.selected?(source.slug) %>
      <a
        class="filter-chip<%= " is-active" if active %>"
        href="<%= @filter.toggle_url(source.slug) %>"
        data-source="<%= source.slug %>"
        aria-pressed="<%= active %>"
      ><%= source.label %></a>
    <% end %>
  </div>
</div>

<div data-events>
  <%== erb :events_list, layout: false %>
</div>

<script src="/filters.js" defer></script>

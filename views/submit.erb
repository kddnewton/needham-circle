<nav class="back-nav"><a href="/" class="back-link">&larr; Back to events</a></nav>

<h2>Submit an Event</h2>

<% if @submitted %>
  <div class="thanks" role="status">Thanks! Your submission has been received and is awaiting approval.</div>
<% else %>
  <% if @form_error %>
    <div class="error-summary" role="alert">There was a problem with your submission. Please check the fields and try again.</div>
  <% end %>

  <form method="post" action="/submit">
    <input type="hidden" name="authenticity_token" value="<%= session[:csrf] %>">

    <div class="field">
      <label for="title">Title</label>
      <input id="title" type="text" name="title" required maxlength="200" value="<%= @event.value_for(:title) %>">
      <% @event.errors_for(:title).each do |error| %>
        <span class="field-error"><%= error %></span>
      <% end %>
    </div>

    <div class="field">
      <label for="contact">Contact</label>
      <input id="contact" type="email" name="contact" required maxlength="200" value="<%= @event.value_for(:contact) %>">
      <small class="field-hint">An email address so our moderators can reach you about your event. It is not shown publicly.</small>
      <% @event.errors_for(:contact).each do |error| %>
        <span class="field-error"><%= error %></span>
      <% end %>
    </div>

    <div class="field">
      <label for="start_time">Start</label>
      <input id="start_time" type="datetime-local" name="start_time" required value="<%= @event.value_for(:start_time) %>">
      <% @event.errors_for(:start_time).each do |error| %>
        <span class="field-error"><%= error %></span>
      <% end %>
    </div>

    <div class="field">
      <label for="end_time">End</label>
      <input id="end_time" type="datetime-local" name="end_time" required value="<%= @event.value_for(:end_time) %>">
      <% @event.errors_for(:end_time).each do |error| %>
        <span class="field-error"><%= error %></span>
      <% end %>
    </div>

    <div class="field">
      <label for="location">Location</label>
      <input id="location" type="text" name="location" maxlength="200" value="<%= @event.value_for(:location) %>">
      <% @event.errors_for(:location).each do |error| %>
        <span class="field-error"><%= error %></span>
      <% end %>
    </div>

    <div class="field">
      <label for="url">URL</label>
      <input
        id="url"
        type="url"
        name="url"
        maxlength="500"
        value="<%= @event.value_for(:url) %>"
        pattern="https://.*"
      >
      <% @event.errors_for(:url).each do |error| %>
        <span class="field-error"><%= error %></span>
      <% end %>
    </div>

    <div class="field">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="4" maxlength="2000"><%= @event.value_for(:description) %></textarea>
      <% @event.errors_for(:description).each do |error| %>
        <span class="field-error"><%= error %></span>
      <% end %>
    </div>

    <p><button type="submit">Submit</button></p>
  </form>
<% end %>
